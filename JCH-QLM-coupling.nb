  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "35e3f718-41cc-456f-b8bc-cf3583f8b247"],
 StyleBox[")",
  FontWeight->"Bold"],
 "\n\nGenerally we label the parameters (previously ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Theta]", ",", "\[Phi]"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\theta, \\phi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43544594-10e8-46bc-8268-00e7ff1ffeb9"],
 ") as follows.\n\n",
 "At matter sites:",
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox["\[Alpha]", "1"], TraditionalForm], "errors" -> {}, 
      "input" -> "\\alpha_1", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "cad80bdc-23d3-45a9-8481-316b526af1d9"],
 "given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox["\[CapitalDelta]", "1"], TraditionalForm], 
      "errors" -> {}, "input" -> "\\Delta_1", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], ",", " ", "g"}], TraditionalForm]],
  ExpressionUUID->"af5af5a2-d6c3-47d4-9d7a-fa4362b5c3ce"],
 " and n = 1\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox["\[Alpha]", "3"], TraditionalForm], "errors" -> {}, 
      "input" -> "\\alpha_3", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "7964d24e-4e8f-4a5a-b636-56a6c9be15ab"],
 "given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox["\[CapitalDelta]", "3"], TraditionalForm], 
      "errors" -> {}, "input" -> "\\Delta_3", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], ",", " ", "g"}], TraditionalForm]],
  ExpressionUUID->"ffa5dd65-8ac5-423c-bf1a-1f58ebea3c14"],
 " and n = 1\n",
 "At link sites:",
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox["\[Alpha]", "2"], TraditionalForm], "errors" -> {}, 
