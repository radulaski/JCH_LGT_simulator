Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{"\<\"Hubbard-interaction term: \"\>", "\[InvisibleSpace]", 
    InterpretationBox[
     TemplateBox[{
       TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
         InterpretationBox[
          TemplateBox[{"b", 
            TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"], 
            
            TemplateBox[{",", "\",\"", "\"\[Dagger]\""}, 
             "RowWithSeparators"]}, "Subsuperscript", SyntaxForm -> 
           SubsuperscriptBox], 
          QuantumMob`Q3`Dagger[
           $CellContext`b[1]]], 
         InterpretationBox[
          SubscriptBox["b", 
           TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
          $CellContext`b[2]]}, "RowWithSeparators"]},
      "RowDefault"],
     QuantumMob`Q3`Multiply[
      QuantumMob`Q3`Dagger[
       $CellContext`b[1]], 
      $CellContext`b[2]]]}], "+", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        InterpretationBox[
         TemplateBox[{"b", 
           TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"\[Dagger]\""}, "RowWithSeparators"]},
           "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         QuantumMob`Q3`Dagger[
          $CellContext`b[2]]], 
        InterpretationBox[
         SubscriptBox["b", 
          TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
         $CellContext`b[1]]}, "RowWithSeparators"]},
     "RowDefault"],
    QuantumMob`Q3`Multiply[
     QuantumMob`Q3`Dagger[
      $CellContext`b[2]], 
     $CellContext`b[1]]]}],
  SequenceForm["Hubbard-interaction term: ", QuantumMob`Q3`Multiply[
     QuantumMob`Q3`Dagger[
      $CellContext`b[1]], 
     $CellContext`b[2]] + QuantumMob`Q3`Multiply[
     QuantumMob`Q3`Dagger[
      $CellContext`b[2]], 
     $CellContext`b[1]]],
  Editable->False]], "Print",
 CellChangeTimes->{
  3.990860514045333*^9, {3.990860673820588*^9, 3.990860683246277*^9}, 
   3.990861154189433*^9, {3.990861555190707*^9, 3.990861593815761*^9}, 
   3.990867510085544*^9, 3.990868052375966*^9},
 CellLabel->
  "During evaluation of \
In[1]:=",ExpressionUUID->"f58bdea8-7d21-4b04-916f-f24588dcac99"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{"\<\"Polariton state \\!\\(\\*TemplateBox[<|\\\"boxes\\\" -> \
FormBox[RowBox[{\\\"|\\\", SuperscriptBox[StyleBox[\\\"n\\\", \\\"TI\\\"], \\\
\"+\\\"], \\\"\[RightAngleBracket]\\\"}], TraditionalForm], \\\"errors\\\" -> \
{}, \\\"input\\\" -> \\\"|n^+\\\\\\\\rangle\\\", \\\"state\\\" -> \\\"Boxes\\\
\"|>,\\\"TeXAssistantTemplate\\\"]\\): \"\>", "\[InvisibleSpace]", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
    InterpretationBox[
     TemplateBox[{
       TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
         SubscriptBox[
          TagBox[
           RowBox[{"(", 
             RowBox[{
               RowBox[{"-", "1"}], "+", "n"}], ")"}], DisplayForm], 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["b", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`b[1]]}, "RowWithSeparators"]], 
         SubscriptBox[
          TagBox[
           RowBox[{"(", 
             FractionBox["1", "2"], ")"}], DisplayForm], 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["s", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`s[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
        "RowWithSeparators"]},
      "Ket"],
     Ket[<|$CellContext`b[1] -> -1 + $CellContext`n, $CellContext`s[
        1, QuantumMob`Q3`$] -> Rational[1, 2]|>]]}], "+", 
   RowBox[{
    InterpretationBox[
     TemplateBox[{
       TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
         SubscriptBox["n", 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["b", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`b[1]]}, "RowWithSeparators"]], 
         SubscriptBox[
          TagBox[
           RowBox[{"(", 
             RowBox[{"-", 
               FractionBox["1", "2"]}], ")"}], DisplayForm], 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["s", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`s[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
        "RowWithSeparators"]},
      "Ket"],
     Ket[<|$CellContext`b[1] -> $CellContext`n, $CellContext`s[
        1, QuantumMob`Q3`$] -> Rational[-1, 2]|>]], " ", 
    RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}],
  SequenceForm[
  "Polariton state \!\(\*TemplateBox[<|\"boxes\" -> FormBox[RowBox[{\"|\", \
SuperscriptBox[StyleBox[\"n\", \"TI\"], \"+\"], \"\[RightAngleBracket]\"}], \
TraditionalForm], \"errors\" -> {}, \"input\" -> \"|n^+\\\\rangle\", \
\"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\): ", 
   Cos[$CellContext`\[Theta]] 
    Ket[<|$CellContext`b[1] -> -1 + $CellContext`n, $CellContext`s[
        1, QuantumMob`Q3`$] -> Rational[1, 2]|>] + 
   Ket[<|$CellContext`b[1] -> $CellContext`n, $CellContext`s[
        1, QuantumMob`Q3`$] -> Rational[-1, 2]|>] Sin[$CellContext`\[Theta]]],
  
  Editable->False]], "Print",
 CellChangeTimes->{
  3.990860514045333*^9, {3.990860673820588*^9, 3.990860683246277*^9}, 
   3.990861154189433*^9, {3.990861555190707*^9, 3.990861593815761*^9}, 
   3.990867510085544*^9, 3.990868052379521*^9},
 CellLabel->
  "During evaluation of \
In[1]:=",ExpressionUUID->"519919e0-0d16-47cf-a700-dfcf19972367"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{"\<\"Polariton state \\!\\(\\*TemplateBox[<|\\\"boxes\\\" -> \
FormBox[RowBox[{\\\"|\\\", SuperscriptBox[StyleBox[\\\"n\\\", \\\"TI\\\"], \\\
\"-\\\"], \\\"\[RightAngleBracket]\\\"}], TraditionalForm], \\\"errors\\\" -> \
{}, \\\"input\\\" -> \\\"|n^-\\\\\\\\rangle\\\", \\\"state\\\" -> \\\"Boxes\\\
\"|>,\\\"TeXAssistantTemplate\\\"]\\): \"\>", "\[InvisibleSpace]", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
    InterpretationBox[
     TemplateBox[{
       TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
         SubscriptBox["n", 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["b", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`b[1]]}, "RowWithSeparators"]], 
         SubscriptBox[
          TagBox[
           RowBox[{"(", 
             RowBox[{"-", 
               FractionBox["1", "2"]}], ")"}], DisplayForm], 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["s", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`s[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
        "RowWithSeparators"]},
      "Ket"],
     Ket[<|$CellContext`b[1] -> $CellContext`n, $CellContext`s[
        1, QuantumMob`Q3`$] -> Rational[-1, 2]|>]]}], "-", 
   RowBox[{
    InterpretationBox[
     TemplateBox[{
       TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
         SubscriptBox[
          TagBox[
           RowBox[{"(", 
             RowBox[{
               RowBox[{"-", "1"}], "+", "n"}], ")"}], DisplayForm], 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["b", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`b[1]]}, "RowWithSeparators"]], 
         SubscriptBox[
          TagBox[
           RowBox[{"(", 
             FractionBox["1", "2"], ")"}], DisplayForm], 
          TemplateBox[{",", "\",\"", 
            InterpretationBox[
             SubscriptBox["s", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
             $CellContext`s[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
        "RowWithSeparators"]},
      "Ket"],
     Ket[<|$CellContext`b[1] -> -1 + $CellContext`n, $CellContext`s[
        1, QuantumMob`Q3`$] -> Rational[1, 2]|>]], " ", 
    RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}],
  SequenceForm[
  "Polariton state \!\(\*TemplateBox[<|\"boxes\" -> FormBox[RowBox[{\"|\", \
SuperscriptBox[StyleBox[\"n\", \"TI\"], \"-\"], \"\[RightAngleBracket]\"}], \
TraditionalForm], \"errors\" -> {}, \"input\" -> \"|n^-\\\\rangle\", \
\"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\): ", 
   Cos[$CellContext`\[Theta]] 
    Ket[<|$CellContext`b[1] -> $CellContext`n, $CellContext`s[
        1, QuantumMob`Q3`$] -> Rational[-1, 2]|>] - 
   Ket[<|$CellContext`b[1] -> -1 + $CellContext`n, $CellContext`s[
       1, QuantumMob`Q3`$] -> Rational[1, 2]|>] Sin[$CellContext`\[Theta]]],
  Editable->False]], "Print",
 CellChangeTimes->{
  3.990860514045333*^9, {3.990860673820588*^9, 3.990860683246277*^9}, 
   3.990861154189433*^9, {3.990861555190707*^9, 3.990861593815761*^9}, 
   3.990867510085544*^9, 3.990868052381708*^9},
 CellLabel->
  "During evaluation of \
In[1]:=",ExpressionUUID->"dfd767a2-ccd4-4617-ad7e-aaedcdc9fa3d"]
}, Open  ]]
}, Open  ]],

Cell[TextData[{
 "Next we define the energies of polariton states, which will be needed in \
the Schrieffer-Wolff procedure. Note that in the code we denote ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["e", "TI"]], "\[LongEqual]", "\[Omega]"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\omega_e = \\omega", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a8e769d1-4fd8-415b-a9a9-fa1508e800c6"],
 " (constant). We use the label \[OpenCurlyDoubleQuote]D\
\[CloseCurlyDoubleQuote] instead of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[CapitalDelta]", TraditionalForm], "errors" -> {}, 
     "input" -> "\\Delta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "58896079-6e47-4277-9265-7c1bd1b30201"],
 "."
}], "Text",
 CellChangeTimes->{{3.9862703589981737`*^9, 3.986270399934494*^9}, {
  3.98627126629401*^9, 3.9862712686714563`*^9}, {3.990860723075768*^9, 
  3.990860738176429*^9}, {3.990867605158477*^9, 3.990867663236005*^9}, {
  3.9908679569663267`*^9, 
  3.9908679715163317`*^9}},ExpressionUUID->"6146786c-2f97-48ac-aaca-\
a35c029196c7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EpMinusD", "[", 
     RowBox[{"n_", ",", " ", "D_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Omega]", "-", "D"}], ")"}], "*", "n"}], " ", "+", " ", 
     RowBox[{"D", "/", "2"}], "-", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"D", "/", "2"}], ")"}], "^", "2"}], "+", 
       RowBox[{
        RowBox[{"g", "^", "2"}], "*", "n"}]}], "]"}]}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    SuperscriptBox["n", "-"], " ", "polarition"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EpPlusD", "[", 
     RowBox[{"n_", ",", " ", "D_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Omega]", "-", "D"}], ")"}], "*", "n"}], " ", "+", " ", 
     RowBox[{"D", "/", "2"}], "+", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"D", "/", "2"}], ")"}], "^", "2"}], "+", 
       RowBox[{
        RowBox[{"g", "^", "2"}], "*", "n"}]}], "]"}]}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    SuperscriptBox["n", "+"], " ", "polarition"}], " ", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9862712729602833`*^9, 3.986271296092783*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"5d2ebdc1-15e3-4455-a17e-292ceb8e9622"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Gauge-invariant Interaction - Coupling Coefficient", "Chapter",
 CellChangeTimes->{{3.986270540149893*^9, 3.986270554917272*^9}, {
  3.9862707379812803`*^9, 3.986270739686308*^9}, {3.986277898257668*^9, 
  3.98627792152967*^9}, {3.9908607735664988`*^9, 3.990860799167152*^9}, {
  3.9908629364646597`*^9, 
  3.99086295537978*^9}},ExpressionUUID->"d08c7963-ba38-4ee9-92a6-\
fe05f3f34da2"],

Cell[TextData[{
 "One needs to  compute,\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["K", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}], 
          StyleBox["eff", FontSlant -> "Plain"]], "\[LongEqual]", 
         FractionBox["1", "2"], 
         UnderscriptBox["\[Sum]", 
          StyleBox["k", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], 
         SubscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["j", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{
             FractionBox["1", 
              RowBox[{
                SubsuperscriptBox[
                 StyleBox["E", "TI"], 
                 StyleBox["i", "TI"], 
                 StyleBox["JC", FontSlant -> "Plain"]], "-", 
                SubsuperscriptBox[
                 StyleBox["E", "TI"], 
                 StyleBox["k", "TI"], 
                 StyleBox["JC", FontSlant -> "Plain"]]}]], "-", 
             FractionBox["1", 
              RowBox[{
                SubsuperscriptBox[
                 StyleBox["E", "TI"], 
                 StyleBox["k", "TI"], 
                 StyleBox["JC", FontSlant -> "Plain"]], "-", 
                SubsuperscriptBox[
                 StyleBox["E", "TI"], 
                 StyleBox["j", "TI"], 
                 StyleBox["JC", FontSlant -> "Plain"]]}]]}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "K^\\mathrm{eff}_{ij} = \\frac12 \\sum_k V_{ik} V_{kj} \\left( \
\\frac1{E^\\mathrm{JC}_{i}- E^\\mathrm{JC}_{k}}- \\frac1{E^\\mathrm{JC}_{k}- \
E^\\mathrm{JC}_{j}}  \\right)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9c963ddd-caa9-4199-ad61-aeded0ac32f3"],
 ",\n\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["j", "TI"], TraditionalForm], "errors" -> {}, "input" -> "j ",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "418e0e25-665e-4002-849c-f98da92e3ac6"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["i", "TI"], TraditionalForm], "errors" -> {}, "input" -> "i", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6eb759bf-35ef-4e49-ad1a-cffc354e56fc"],
 " are the initial and final states respectively, while ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["k", "TI"], TraditionalForm], "errors" -> {}, "input" -> "k", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "64ce7030-621c-4986-b114-faa7ed15d36d"],
 " is the intermediate state. We separately compute the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], 
         SubscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["j", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "V_{ik} V_{kj}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "93538d5b-5b5a-45a3-b2f7-f5c35c3899ee"],
 " factors coming from off-diagonal part of the Hamiltonian (the \
perturbation) and the remaining \[OpenCurlyDoubleQuote]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        StyleBox["E", "TI"], TraditionalForm], "errors" -> {}, "input" -> "E",
       "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "d3c553bb-61c8-4497-9ee8-5ea8a04ec4b9"],
 "factors\[CloseCurlyDoubleQuote] which depends on the diagonal part of the \
Hamiltonian (the polariton energy levels)"
}], "Text",
 CellChangeTimes->{{3.9862707924993677`*^9, 3.986270932582758*^9}, {
  3.9908608046016703`*^9, 3.990860816285887*^9}, {3.990860846347641*^9, 
  3.990860847859713*^9}, {3.9908629598967037`*^9, 3.990862968775234*^9}, {
  3.9908630264538727`*^9, 3.9908633482674093`*^9}, {3.9908637769512777`*^9, 
  3.990863779230154*^9}},ExpressionUUID->"28ca6300-afbe-4e91-8365-\
ea041e0e41d8"],

Cell[CellGroupData[{

Cell[TextData[{
 "The ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], 
         SubscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["j", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "V_{ik} V_{kj}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a855ff48-93da-471c-adf1-d361f166b661"],
 " Factors "
}], "Section",
 CellChangeTimes->{{3.98627074660317*^9, 3.986270757584283*^9}, {
  3.9862708002772017`*^9, 3.9862708142883167`*^9}, {3.9862709358666897`*^9, 
  3.986270942433662*^9}, {3.986270972710123*^9, 3.986270974807654*^9}, {
  3.990863367377643*^9, 3.990863371475223*^9}, {3.990863768566749*^9, 
  3.9908637702891083`*^9}},ExpressionUUID->"5aebd19c-0040-4a54-8969-\
af0d4585fb7a"],

Cell[TextData[{
 "The hopping coefficients in the polariton basis, are obtained here. They \
depend on the initial and final polariton state. In full:\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["i", "TI"], "\[Dagger]"], 
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["j", "TI"]], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          RowBox[{
            SubscriptBox[
             StyleBox["n", "TI"], 
             StyleBox["i", "TI"]], ",", 
            SubscriptBox[
             StyleBox["n", "TI"], 
             StyleBox["j", "TI"]]}], LimitsPositioning -> True], 
         UnderscriptBox["\[Sum]", 
          RowBox[{
            SubscriptBox["\[Alpha]", 
             StyleBox["i", "TI"]], ",", 
            SubscriptBox["\[Alpha]", 
             StyleBox["j", "TI"]]}], LimitsPositioning -> True], 
         UnderscriptBox["\[Sum]", 
          RowBox[{
            SubscriptBox["\[Beta]", 
             StyleBox["i", "TI"]], ",", 
            SubscriptBox["\[Beta]", 
             StyleBox["j", "TI"]]}], LimitsPositioning -> True], 
         StyleBox["J", "TI"], 
         SubsuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubscriptBox[
               StyleBox["n", "TI"], 
               StyleBox["i", "TI"]], ",", 
              SubscriptBox[
               StyleBox["n", "TI"], 
               StyleBox["j", "TI"]]}], ")"}], 
          RowBox[{
            SubscriptBox["\[Beta]", 
             StyleBox["i", "TI"]], ",", 
            SubscriptBox["\[Beta]", 
             StyleBox["j", "TI"]]}], 
          RowBox[{
            SubscriptBox["\[Alpha]", 
             StyleBox["i", "TI"]], ",", 
            SubscriptBox["\[Alpha]", 
             StyleBox["j", "TI"]]}]], "|", 
         SubsuperscriptBox[
          StyleBox["p", "TI"], 
          StyleBox["i", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["n", "TI"], 
             StyleBox["i", "TI"]], "+", "1", ",", 
            SubscriptBox["\[Beta]", 
             StyleBox["i", "TI"]]}]], 
         SubsuperscriptBox[
          StyleBox["p", "TI"], 
          StyleBox["j", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["n", "TI"], 
             StyleBox["j", "TI"]], "-", "1", ",", 
            SubscriptBox["\[Beta]", 
             StyleBox["j", "TI"]]}]], "\[RightAngleBracket]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             SubsuperscriptBox[
              StyleBox["p", "TI"], 
              StyleBox["i", "TI"], 
              RowBox[{
                SubscriptBox[
                 StyleBox["n", "TI"], 
                 StyleBox["i", "TI"]], ",", 
                SubscriptBox["\[Alpha]", 
                 StyleBox["i", "TI"]]}]], 
             SubsuperscriptBox[
              StyleBox["p", "TI"], 
              StyleBox["j", "TI"], 
              RowBox[{
                SubscriptBox[
                 StyleBox["n", "TI"], 
                 StyleBox["j", "TI"]], ",", 
                SubscriptBox["\[Alpha]", 
                 StyleBox["j", "TI"]]}]], "|"}]}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "a^\\dag_i a_j =\\sum_{n_i, n_j}\\sum_{\\alpha_i, \\alpha_j} \
\\sum_{\\beta_i,\\beta_j} J(n_i, n_j)^{ \\alpha_i, \\alpha_j}_{\\beta_i, \
\\beta_j} |p^{n_i+1, \\beta_i}_i p^{n_j-1, \\beta_j}_j \\rangle \\langle \
p^{n_i, \\alpha_i}_i p^{n_j, \\alpha_j}_j|", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0e29bef0-6777-443d-a241-6646aa57313b"],
 ".\n\nHowever, for us only specific terms are relevant, specifically:\n\n\t ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["A", "TI"], "1"], " ", 
         StyleBox["from", FontSlant -> "Plain"], " ", "\[Tilde]", 
         SuperscriptBox["|1", "-"], ",", "0", "\[RightAngleBracket]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{"0", ",", 
             SuperscriptBox["1", "-"], "|"}]}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "A_1 \\,\\mathrm{from}\\, \\sim| 1^{-}, 0\\rangle \\langle 0, 1^-|", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bc7c601b-2d47-457b-af78-b26aed0d231a"],
 ", \n\t ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["A", "TI"], "2"], " ", 
         StyleBox["from", FontSlant -> "Plain"], " ", "\[Tilde]", 
         SuperscriptBox["|1", "+"], ",", "0", "\[RightAngleBracket]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{"0", ",", 
             SuperscriptBox["1", "-"], "|"}]}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "A_2 \\,\\mathrm{from}\\, \\sim| 1^{+}, 0\\rangle \\langle 0, 1^-|", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0ba03c27-9a91-4441-81fb-0a1512827b27"],
 "\n\t ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["B", "TI"], "1"], " ", 
         StyleBox["from", FontSlant -> "Plain"], " ", "\[Tilde]", 
         SuperscriptBox["|2", "-"], ",", "0", "\[RightAngleBracket]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             SuperscriptBox["1", "-"], ",", 
             SuperscriptBox["1", "-"], "|"}]}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "B_1  \\,\\mathrm{from}\\,\\sim|2^{-}, 0\\rangle \\langle 1^{-} ,1^-|", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e81606b3-ee7e-4c41-971b-45b35ff0f3cb"],
 ", \n\t ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["B", "TI"], "2"], " ", 
         StyleBox["from", FontSlant -> "Plain"], " ", "\[Tilde]", 
         SuperscriptBox["|2", "-"], ",", "0", "\[RightAngleBracket]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             SuperscriptBox["1", "+"], ",", 
             SuperscriptBox["1", "-"], "|"}]}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "B_2  \\,\\mathrm{from}\\,\\sim|2^{-}, 0\\rangle \\langle 1^{+} ,1^{-}|",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c735e98-dc1e-424b-a789-9fd68d038db8"],
 ", \n\t and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"+", 
         StyleBox["H", "TI"], ".", 
         StyleBox["c", "TI"], "."}], TraditionalForm], "errors" -> {}, 
     "input" -> "+ H.c.", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9d0cd18e-a385-44e2-8727-d340479c0bed"],
 "\n\n\n",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
