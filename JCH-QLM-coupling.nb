Notebook[{

Cell[CellGroupData[{
Cell["JCH-QLM Schrieffer Wolff", "Title",
 CellChangeTimes->{{3.986269631243156*^9, 3.986269671559112*^9}, {
  3.990860354261688*^9, 
  3.990860355250669*^9}},ExpressionUUID->"7a288f05-9223-4e2a-adcb-\
bd03ae5e9c4e"],

Cell[CellGroupData[{

Cell["The JCH Setup ", "Chapter",
 CellChangeTimes->{{3.986269797521323*^9, 3.986269798322619*^9}, {
  3.990862943769176*^9, 
  3.990862951178544*^9}},ExpressionUUID->"e55b053e-1bee-4f33-9693-\
629da3c05fc6"],

Cell[TextData[{
 "Here we list some equations needed for the calculation. We consider the JCH \
in the regime where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Omega]", 
          StyleBox["c", "TI"]], 
         SubscriptBox["\[NotEqual]\[Omega]", 
          StyleBox["e", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\omega_c \\neq \\omega_e", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d004c3c8-4068-4e08-a2bc-6488ee49bc49"],
 " and  we have the following eigenstates:\n\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SuperscriptBox[
          StyleBox["n", "TI"], "+"], "\[RightAngleBracket]", "\[LongEqual]", 
         "sin", 
         RowBox[{"(", 
           SubscriptBox["\[Theta]", 
            StyleBox["n", "TI"]], ")"}], "|", 
         StyleBox["n", "TI"], ",", "\[DownArrow]", "\[RightAngleBracket]", 
         "+", "cos", 
         RowBox[{"(", 
           SubscriptBox["\[Theta]", 
            StyleBox["n", "TI"]], ")"}], "|", 
         StyleBox["n", "TI"], "-", "1", ",", "\[UpArrow]", 
         "\[RightAngleBracket]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "| n^+ \\rangle = \\sin(\\theta_n) |n, \\downarrow \\rangle + \
\\cos(\\theta_n) | n-1, \\uparrow \\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a73abb29-6056-4f2a-96ce-aa906775e028"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SuperscriptBox[
          StyleBox["n", "TI"], "-"], "\[RightAngleBracket]", "\[LongEqual]", 
         "cos", 
         RowBox[{"(", 
           SubscriptBox["\[Theta]", 
            StyleBox["n", "TI"]], ")"}], "|", 
         StyleBox["n", "TI"], ",", "\[DownArrow]", "\[RightAngleBracket]", 
         "-", "sin", 
         RowBox[{"(", 
           SubscriptBox["\[Theta]", 
            StyleBox["n", "TI"]], ")"}], "|", 
         StyleBox["n", "TI"], "-", "1", ",", "\[UpArrow]", 
         "\[RightAngleBracket]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "| n^- \\rangle = \\cos(\\theta_n) |n, \\downarrow \\rangle - \
\\sin(\\theta_n) | n-1, \\uparrow \\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c00643aa-8674-44d8-ba53-cfa7b1b4e7c7"],
 "\n\nwhere,\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"tan", 
         RowBox[{"2", 
           SubscriptBox["\[Theta]", 
            StyleBox["n", "TI"]]}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", 
            StyleBox["g", "TI"], 
            SqrtBox[
             StyleBox["n", "TI"]]}], "\[CapitalDelta]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\tan{2 \\theta_n} =  \\frac{2g \\sqrt{n}}{\\Delta}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c0641135-8b1a-45d1-a149-44340ad2362a"],
 "\n\nand the trigonometric functions can be expressed as,\n\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cos", 
         RowBox[{"(", 
           SubscriptBox["\[Theta]", 
            StyleBox["n", "TI"]], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          SqrtBox["2"]], 
         SqrtBox[
          RowBox[{"1", "+", 
            FractionBox["\[CapitalDelta]", 
             SqrtBox[
              RowBox[{
                SuperscriptBox["\[CapitalDelta]", "2"], "+", "4", 
                SuperscriptBox[
                 StyleBox["g", "TI"], "2"], 
                StyleBox["n", "TI"]}]]]}]], "\[LongEqual]", 
         FractionBox["1", 
          SqrtBox["2"]], 
         SqrtBox[
          RowBox[{"1", "+", "\[CapitalDelta]", "/", "\[Chi]"}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\cos(\\theta_n) =  \\frac1{\\sqrt{2}} \\sqrt{1+ \
\\frac{\\Delta}{\\sqrt{\\Delta^2 + 4g^2 n}}} = \\frac1{\\sqrt{2}} \
\\sqrt{1+\\Delta/\\chi}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f0981d2a-2e4e-4a72-a189-d5b5d2213c87"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"sin", 
         RowBox[{"(", 
           SubscriptBox["\[Theta]", 
            StyleBox["n", "TI"]], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          SqrtBox["2"]], 
         SqrtBox[
          RowBox[{"1", "-", 
            FractionBox["\[CapitalDelta]", 
             SqrtBox[
              RowBox[{
                SuperscriptBox["\[CapitalDelta]", "2"], "+", "4", 
                SuperscriptBox[
                 StyleBox["g", "TI"], "2"], 
                StyleBox["n", "TI"]}]]]}]], "\[LongEqual]", 
         FractionBox["1", 
          SqrtBox["2"]], 
         SqrtBox[
          RowBox[{"1", "-", "\[CapitalDelta]", "/", "\[Chi]"}]]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\sin(\\theta_n) =  \\frac1{\\sqrt{2}} \\sqrt{1- \
\\frac{\\Delta}{\\sqrt{\\Delta^2 + 4g^2 n}}} = \\frac1{\\sqrt{2}} \
\\sqrt{1-\\Delta/\\chi}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "61f30435-0e8d-40a0-8d5d-c94a2d8285f7"],
 "\n"
}], "Text",
 CellChangeTimes->{{3.986269958075461*^9, 3.9862701002274227`*^9}, 
   3.986286483813044*^9, {3.987500631080694*^9, 3.987500631957159*^9}, 
   3.9875060664084167`*^9, {3.990860372220874*^9, 3.9908604050076857`*^9}, {
   3.9908625310655518`*^9, 3.990862535776511*^9}, {3.990862607835539*^9, 
   3.990862672023094*^9}, {3.990862746665164*^9, 3.9908627478931026`*^9}, {
   3.9908639595318937`*^9, 3.9908639609842*^9}, {3.990867380420025*^9, 
   3.990867404002063*^9}},ExpressionUUID->"2f1bc51b-8f28-4ce7-b7e4-\
addd2fb7b13f"],

Cell["We begin by defining terms of the Hamiltonian.", "Text",
 CellChangeTimes->{{3.986270112123232*^9, 3.986270176672307*^9}, 
   3.986270207887128*^9, {3.986270244641467*^9, 3.986270249678891*^9}, {
   3.9862703174370747`*^9, 3.986270337410812*^9}, {3.986800642039155*^9, 
   3.986800642870315*^9}, {3.9908604283779097`*^9, 3.9908604484938707`*^9}, {
   3.990867936692525*^9, 
   3.990867942569336*^9}},ExpressionUUID->"4c332f64-45f0-492b-bebc-\
236423b14ff9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Hamiltonian", " ", "Defs"}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Let", "[", 
     RowBox[{"Boson", ",", " ", "b"}], "]"}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"define", " ", "boson", " ", "dof"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Let", "[", 
    RowBox[{"Spin", ",", " ", "s", ",", " ", 
     RowBox[{"Spin", " ", "->", " ", 
      RowBox[{"1", "/", "2"}]}]}], "]"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"define", " ", "spin", " ", "dof"}], " ", "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Hubbard-interaction term: \>\"", ",", " ", 
     RowBox[{"hop", " ", "=", " ", 
      RowBox[{
       RowBox[{"Hop", "[", 
        RowBox[{"b", "@", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "+", 
       RowBox[{"Hop", "[", 
        RowBox[{"b", "@", 
         RowBox[{"{", 
          RowBox[{"2", ",", "1"}], "}"}]}], "]"}]}]}]}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PolaritonState", "[", 
      RowBox[{"n_", ",", " ", "a_", ",", " ", "i_", ",", " ", "\[Theta]_"}], 
      "]"}], " ", ":=", " ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"n", "==", "0"}], ",", " ", 
       RowBox[{"Ket", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"b", "[", "i", "]"}], "->", "0"}], ",", " ", 
         RowBox[{
          RowBox[{"s", "[", "i", "]"}], "->", 
          RowBox[{
           RowBox[{"-", "1"}], "/", "2"}]}]}], "]"}], ",", " ", 
       RowBox[{"(*", " ", 
        RowBox[{"returns", " ", "a", " ", "polariton", " ", "state", " ", 
         TemplateBox[<|"boxes" -> FormBox[
             RowBox[{"|", 
               SuperscriptBox[
                StyleBox["n", "TI"], 
                StyleBox["a", "TI"]], "\[RightAngleBracket] ", 
               StyleBox["a", "TI"], "\[Element]", "\[PlusMinus]"}], 
             TraditionalForm], "errors" -> {}, "input" -> 
           "| n^a \\rangle \\, a \\in \\pm", "state" -> "Boxes"|>,
          "TeXAssistantTemplate"], " ", "at", " ", "position", " ", 
         TemplateBox[<|"boxes" -> FormBox[
             StyleBox["i", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
           "i", "state" -> "Boxes"|>,
          "TeXAssistantTemplate"]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"a", "==", "1"}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", 
           RowBox[{"Ket", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"b", "[", "i", "]"}], "->", " ", "n"}], ",", " ", 
             RowBox[{
              RowBox[{"s", "[", "i", "]"}], "->", 
              RowBox[{
               RowBox[{"-", "1"}], "/", "2"}]}]}], "]"}]}], " ", "+", 
          RowBox[{
           RowBox[{"Cos", "[", "\[Theta]", "]"}], "*", " ", 
           RowBox[{"Ket", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"b", "[", "i", "]"}], "->", 
              RowBox[{"n", "-", "1"}]}], ",", " ", 
             RowBox[{
              RowBox[{"s", "[", "i", "]"}], "->", " ", 
              RowBox[{"1", "/", "2"}]}]}], "]"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", "\[Theta]", "]"}], "*", 
           RowBox[{"Ket", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"b", "[", "i", "]"}], "->", " ", "n"}], ",", " ", 
             RowBox[{
              RowBox[{"s", "[", "i", "]"}], "->", 
              RowBox[{
               RowBox[{"-", "1"}], "/", "2"}]}]}], "]"}]}], " ", "-", 
          RowBox[{
           RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", " ", 
           RowBox[{"Ket", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"b", "[", "i", "]"}], "->", 
              RowBox[{"n", "-", "1"}]}], ",", " ", 
             RowBox[{
              RowBox[{"s", "[", "i", "]"}], "->", " ", 
              RowBox[{"1", "/", "2"}]}]}], "]"}]}]}]}], "\[IndentingNewLine]",
         "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Polariton state \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{\"|\", 
SuperscriptBox[
StyleBox[\"n\", \"TI\"], \"+\"], \"\[RightAngleBracket]\"}], \
TraditionalForm], \"errors\" -> {}, \"input\" -> \"|n^+\\\\rangle\", \
\"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\): \>\"", ",", 
     RowBox[{"Refine", "[", 
      RowBox[{
       RowBox[{"PolaritonState", "[", 
        RowBox[{"n", ",", " ", 
         RowBox[{"+", "1"}], ",", " ", "1", ",", " ", "\[Theta]"}], "]"}], 
       ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ">", "0"}], "}"}]}], "]"}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Polariton state \!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{\"|\", 
SuperscriptBox[
StyleBox[\"n\", \"TI\"], \"-\"], \"\[RightAngleBracket]\"}], \
TraditionalForm], \"errors\" -> {}, \"input\" -> \"|n^-\\\\rangle\", \
\"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\): \>\"", ",", 
     RowBox[{"Refine", "[", 
      RowBox[{
       RowBox[{"PolaritonState", "[", 
        RowBox[{"n", ",", " ", 
         RowBox[{"-", "1"}], ",", " ", "1", ",", " ", "\[Theta]"}], "]"}], 
       ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ">", "0"}], "}"}]}], "]"}]}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"site", "-", 
     RowBox[{"dependent", " ", "parameters"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"loc1", " ", "=", " ", 
     RowBox[{"Sequence", "@@", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "\[Theta]1"}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"loc2", " ", "=", " ", 
     RowBox[{"Sequence", "@@", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "\[Theta]2"}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"types", " ", "of", " ", "polaritons"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"P0", "  ", "=", 
     RowBox[{"Sequence", " ", "@@", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["P1", "-"], " ", "=", 
     RowBox[{"Sequence", " ", "@@", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["P1", "+"], " ", "=", 
     RowBox[{"Sequence", " ", "@@", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", 
        RowBox[{"+", "1"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["P2", "-"], " ", "=", " ", 
     RowBox[{"Sequence", " ", "@@", 
      RowBox[{"{", 
       RowBox[{"2", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"use", " ", 
     RowBox[{"as", ":", " ", 
      RowBox[{"PolaritonState", "[", 
       RowBox[{
        RowBox[{"P", "<", 
         SuperscriptBox["n", 
          
          TemplateBox[<|
           "boxes" -> FormBox["\[PlusMinus]", TraditionalForm], 
            "errors" -> {}, "input" -> "\\pm", "state" -> "Boxes"|>,
           "TeXAssistantTemplate"]], ">"}], ",", " ", 
        RowBox[{"loc", "<", "i", ">"}]}], "]"}]}]}], " ", "*)"}]}]}]], "Input",\

