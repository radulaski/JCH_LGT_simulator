Cell[TextData[{
 "Here we compute the remaning factor involving reciprocal energy changes for \
all the different possible processes ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["P", "TI"], "\[Element]", 
         RowBox[{"{", 
           RowBox[{
             SubscriptBox[
              StyleBox["A", "TI"], "1"], ",", 
             SubscriptBox[
              StyleBox["A", "TI"], "2"], ",", 
             SubscriptBox[
              StyleBox["B", "TI"], "1"], ",", 
             SubscriptBox[
              StyleBox["B", "TI"], "2"]}], "}"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "P \\in \\{A_1, A_2, B_1, B_2\\}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "67d9332f-e06c-4c8d-a03d-46147edffd57"],
 "."
}], "Text",
