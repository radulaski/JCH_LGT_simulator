 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"trig", " ", "->", " ", 
    RowBox[{"Ham", ".", " ", "params", "."}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ca1", " ", "=", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"1", "/", "2"}], "*", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"D1", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"D1", "^", "2"}], "+", 
            RowBox[{"4", 
             RowBox[{"g", "^", "2"}]}]}], "]"}]}]}], ")"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sa1", " ", "=", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"1", "/", "2"}], "*", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"D1", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"D1", "^", "2"}], "+", 
            RowBox[{"4", 
             RowBox[{"g", "^", "2"}]}]}], "]"}]}]}], ")"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ca2", " ", "=", " ", 
