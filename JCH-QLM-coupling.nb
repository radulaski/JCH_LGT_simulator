Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ErgDiffA1", "[", 
    RowBox[{"D_", ",", " ", "DPost_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"EpMinusD", "[", 
      RowBox[{"1", ",", " ", "DPost"}], "]"}], " ", "-", " ", 
     RowBox[{"EpMinusD", "[", 
      RowBox[{"1", ",", " ", "D"}], "]"}]}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ErgDiffA2", "[", 
     RowBox[{"D_", ",", " ", "DPost_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"EpPlusD", "[", 
       RowBox[{"1", ",", " ", "DPost"}], "]"}], " ", "-", " ", 
      RowBox[{"EpMinusD", "[", 
       RowBox[{"1", ",", " ", "D"}], "]"}]}], "//", "Simplify"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ErgDiffB1", "[", 
    RowBox[{"D_", ",", " ", "DPost_"}], "]"}], " ", ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"EpMinusD", "[", 
      RowBox[{"2", ",", " ", "DPost"}], "]"}], " ", "-", " ", 
     RowBox[{"EpMinusD", "[", 
      RowBox[{"1", ",", " ", "DPost"}], "]"}], " ", "-", " ", 
     RowBox[{"EpMinusD", "[", 
      RowBox[{"1", ",", " ", "D"}], "]"}]}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ErgDiffB2", "[", 
    RowBox[{"D_", ",", " ", "DPost_"}], "]"}], " ", ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"EpMinusD", "[", 
      RowBox[{"2", ",", " ", "DPost"}], "]"}], " ", "-", " ", 
     RowBox[{"EpPlusD", "[", 
      RowBox[{"1", ",", " ", "DPost"}], "]"}], " ", "-", " ", 
     RowBox[{"EpMinusD", "[", 
      RowBox[{"1", ",", " ", "D"}], "]"}]}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.986271767985362*^9, 3.986271776277635*^9}, {
