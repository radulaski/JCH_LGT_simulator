          RowBox[{"\[Theta]1", "->", "\[Alpha]Post"}], ",", " ", 
          RowBox[{"\[Theta]2", "->", "\[Alpha]"}]}], "}"}]}], "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"B1Func", "[", 
      RowBox[{
      "\[Alpha]_", ",", " ", "\[Alpha]Post_", ",", " ", "\[Beta]Post_"}], 
      "]"}], " ", ":=", " ", 
     RowBox[{"Refine", "[", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"B1", " ", "/.", 
        RowBox[{"{", 
