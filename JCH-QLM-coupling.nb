bbdd66bc9d6e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"initial", " ", "=", " ", 
   RowBox[{
    RowBox[{"PolaritonState", "[", 
     RowBox[{"P0", ",", " ", "loc1"}], "]"}], "**", 
    RowBox[{"PolaritonState", "[", 
     RowBox[{
      SuperscriptBox["P1", "-"], ",", " ", "loc2"}], "]"}]}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"0", " ", 
    SuperscriptBox["1", "-"]}], "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"final", " ", "=", " ", 
   RowBox[{
    RowBox[{"PolaritonState", "[", 
     RowBox[{
      SuperscriptBox["P1", "-"], ",", " ", "loc1"}], "]"}], "**", 
    RowBox[{"PolaritonState", "[", 
     RowBox[{"P0", ",", "loc2"}], "]"}]}]}], "   ", 
  RowBox[{"(*", " ", 
   RowBox[{
    SuperscriptBox["1", "-"], "0"}], " ", "*)"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A1", "=", " ", 
    RowBox[{
     RowBox[{"Dagger", "[", "final", "]"}], "**", "hop", "**", "initial"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"initial", " ", "=", " ", 
   RowBox[{
    RowBox[{"PolaritonState", "[", 
     RowBox[{"P0", ",", " ", "loc1"}], "]"}], "**", 
    RowBox[{"PolaritonState", "[", 
     RowBox[{
      SuperscriptBox["P1", "-"], ",", " ", "loc2"}], "]"}]}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"0", " ", 
    SuperscriptBox["1", "-"]}], "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"final", " ", "=", " ", 
   RowBox[{
    RowBox[{"PolaritonState", "[", 
     RowBox[{
      SuperscriptBox["P1", "+"], ",", " ", "loc1"}], "]"}], "**", 
    RowBox[{"PolaritonState", "[", 
     RowBox[{"P0", ",", "loc2"}], "]"}]}]}], "   ", 
  RowBox[{"(*", " ", 
   RowBox[{
    SuperscriptBox["1", "+"], "0"}], " ", "*)"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A2", " ", "=", " ", 
    RowBox[{
     RowBox[{"Dagger", "[", "final", "]"}], "**", "hop", "**", "initial"}]}], 
   ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"angles", " ", "are", " ", "real"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A1", " ", "=", " ", 
   RowBox[{"Refine", "[", 
    RowBox[{"A1", ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Theta]1", " ", "\[Element]", " ", "Reals"}], ",", " ", 
       RowBox[{"\[Theta]2", "\[Element]", " ", "Reals"}], ",", " ", 
       RowBox[{"\[Phi]1", " ", "\[Element]", " ", "Reals"}]}], "}"}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A2", " ", "=", " ", 
    RowBox[{"Refine", "[", 
     RowBox[{"A2", ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Theta]1", " ", "\[Element]", " ", "Reals"}], ",", " ", 
        RowBox[{"\[Theta]2", "\[Element]", " ", "Reals"}], ",", " ", 
        RowBox[{"\[Phi]1", " ", "\[Element]", " ", "Reals"}]}], "}"}]}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\!\(\*SubscriptBox[\(A\), \(1\)]\): \>\"", ",", " ", "A1"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\!\(\*SubscriptBox[\(A\), \(2\)]\): \>\"", ",", " ", "A2"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9875005813703737`*^9, 3.987500597006445*^9}, {
  3.98750069515203*^9, 3.987500810753125*^9}, {3.987500871219239*^9, 
  3.98750088039098*^9}, {3.987501155732778*^9, 3.9875011623335543`*^9}, {
