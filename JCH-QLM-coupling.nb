Cell[TextData[{
 "Solve for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox["\[CapitalDelta]", "2"], TraditionalForm], 
      "errors" -> {}, "input" -> "\\Delta_2", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "0b37fd74-9408-4288-a251-be271c9c76ab"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[CapitalDelta]", "3"], TraditionalForm], "errors" -> {},
      "input" -> "\\Delta_3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6698c9c6-986c-4f82-8ac9-576925655df0"],
 " given ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[CapitalDelta]", "1"], TraditionalForm], "errors" -> {},
      "input" -> "\\Delta_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "63fd284c-334b-402a-bcc5-1ed1234d4c34"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Lambda]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\lambda", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ed1ec22b-a357-4f8c-84f8-f4dc26ac20e1"],
 " (fulfilling the energy-level-matching regime).\n\nIn the proposed regime \
we set\[LineSeparator]\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["E", "TI"], 
          SuperscriptBox["1", "-"], "3"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["E", "TI"], 
          SuperscriptBox["1", "-"], "1"], "+", "\[Lambda]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "E^3_{1^-} = E^1_{1^-} + \\lambda", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7f2f6bc-0b10-4b4f-98ec-39645d3498c0"],
 ", and\n\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["E", "TI"], 
          SuperscriptBox["2", "-"], "2"], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["E", "TI"], 
          SuperscriptBox["1", "-"], "1"], "+", 
         SubsuperscriptBox[
          StyleBox["E", "TI"], 
          SuperscriptBox["1", "-"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "E^2_{2^-} = E_{1^-}^1 + E_{1^-}^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "00958bc3-313c-4c6b-abb3-a8a01cb398cf"],
 "."
}], "Text",
