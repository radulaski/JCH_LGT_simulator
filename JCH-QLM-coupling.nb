             RowBox[{"g", "^", "2"}]}]}], "]"}]}]}], ")"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ca3", " ", "=", " ", 
     RowBox[{"Sqrt", "[", 
