        RowBox[{"1", "+", 
         RowBox[{"D2", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"D2", "^", "2"}], "+", 
            RowBox[{"4", 
             RowBox[{"g", "^", "2"}]}]}], "]"}]}]}], ")"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
